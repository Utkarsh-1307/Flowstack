# ─── PostgreSQL ───────────────────────────────────────────────────────────────
DATABASE_SECURE_PASSWORD=change_me_in_production
DATABASE_URL=postgresql+asyncpg://engine_admin:change_me_in_production@postgres-db:5432/analytics_platform

# ─── Kafka ────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka-broker:29092
KAFKA_TOPIC_USER_EVENTS=user-events
KAFKA_TOPIC_DLQ=user-events-dlq

# ─── Airflow ──────────────────────────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=your_fernet_key_here
AIRFLOW_SECRET_KEY=your_webserver_secret_key_here

# ─── Alerts ───────────────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your/webhook/url

